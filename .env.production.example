# Copy to .env.production before `npm run cf:build` / production CI.
# NEXT_PUBLIC_* are inlined at build time.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: same as local for server-side features
# OPENROUTER_API_KEY=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://believetheworks.org/media
# R2_MAX_IMAGE_MB=25
