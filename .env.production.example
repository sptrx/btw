# Copy to .env.production before `npm run cf:build` / production CI.
# NEXT_PUBLIC_* are inlined at build time.

# Optional: Scripture Chat app (bible-ai). Defaults to http://localhost:3040/ask if unset.
# NEXT_PUBLIC_BIBLE_AI_URL=https://your-domain.com/ask

# Server-only: bible-ai base URL for Scripture guide on channel comments (POST /api/v1/guide).
# Example local: BIBLE_AI_BASE_URL=http://localhost:3040
# BIBLE_AI_BASE_URL=
# Optional if bible-ai has BIBLE_AI_API_KEY set:
# BIBLE_AI_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: same as local for server-side features
# OPENROUTER_API_KEY=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://believetheworks.org/media
# R2_MAX_IMAGE_MB=25
