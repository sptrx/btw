# Local preview: copy to .dev.vars (gitignored). Production secrets → Cloudflare dashboard / wrangler secret.
NEXTJS_ENV=development

# Mirror .env.local for `npm run cf:preview` (non-NEXT_PUBLIC_* only if used server-side)
# NEXT_PUBLIC_* can be set in wrangler.toml [vars] or dashboard for preview

# Scripture guide on comments (server → bible-ai). Local example:
# BIBLE_AI_BASE_URL=http://localhost:3040
# BIBLE_AI_API_KEY=your_shared_secret
# Optional: header "Bible Q&A" link (defaults to localhost in dev; production defaults to Pages URL)
# NEXT_PUBLIC_BIBLE_AI_URL=http://localhost:3040/ask
