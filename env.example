# Copy to .env.local and fill in values.
#
# Production (Cloudflare): copy to .env.production before `npm run cf:build`
# so NEXT_PUBLIC_* match https://believetheworks.org — see docs/cloudflare-deploy.md

# Supabase (required)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare R2 — S3-compatible storage for channel images/videos
# See docs/cloudflare-r2.md for CORS and public URL setup.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://media.example.com
# R2_MAX_IMAGE_MB=25
# R2_MAX_VIDEO_MB=400
# R2_PROXY_MAX_MB=8
